# ═══════════════════════════════════════════════════════════
# STUDENT FEEDBACK BACKEND - Environment Variables
# ═══════════════════════════════════════════════════════════
# 
# IMPORTANT: 
# - Copy this file to .env and fill in your values
# - NEVER commit .env to git (it's in .gitignore)
# - For Vercel deployment, add these variables in project settings
#
# ═══════════════════════════════════════════════════════════

# SUPABASE DATABASE CONFIGURATION
# Get these values from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anonymous-key-here

# SERVER CONFIGURATION
# Port for local development
PORT=3000

# Environment
# Use: development (local), production (deployed)
NODE_ENV=development

# ═══════════════════════════════════════════════════════════
# OPTIONAL: CORS CONFIGURATION (for production)
# Uncomment and update for specific domains
# ═══════════════════════════════════════════════════════════

# CORS_ORIGIN=https://my-domain.com
# CORS_ORIGIN=https://my-frontend.vercel.app

